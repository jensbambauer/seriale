{
  "name": "seriale",
  "version": "2.0.0",
  "description": "Die Seriale - German Series Festival Website",
  "type": "module",
  "scripts": {
    "dev": "npm run build:dev && concurrently \"npm run hugo:watch\" \"npm run vite:watch\" \"npm run serve\"",
    "build:dev": "npm run hugo:build && npm run vite:build",
    "serve": "npx serve dist -l 3000",
    "hugo:watch": "hugo -s site -d ../dist --watch",
    "hugo:dev": "hugo server -s site -d ../dist --disableFastRender --port 1313",
    "vite:dev": "vite --port 5173",
    "vite:watch": "vite build --watch",
    "build": "npm run hugo:build && npm run vite:build",
    "hugo:build": "hugo -s site -d ../dist",
    "vite:build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@barba/core": "^2.10.3",
    "date-fns": "^3.6.0",
    "gsap": "^3.12.5",
    "jquery": "^3.7.1",
    "masonry-layout": "^4.2.2",
    "smooth-scrollbar": "^8.8.4",
    "swiper": "^11.1.14"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cssnano": "^7.0.6",
    "postcss": "^8.4.49",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.0",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^10.1.3",
    "serve": "^14.2.4",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
